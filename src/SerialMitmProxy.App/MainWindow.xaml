                                        <WrapPanel>
                                            <CheckBox Content="{Binding Localizer[CfgFieldUseInMemory]}"
                                                      IsChecked="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigEditor.SessionUseInMemory, Mode=TwoWay}" />
