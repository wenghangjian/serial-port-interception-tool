<Window x:Class="SerialMitmProxy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Localizer[WindowTitle]}"
        Width="1340"
        Height="860"
        MinWidth="1080"
        MinHeight="680"
        FontFamily="Bahnschrift"
        Background="#F2F6FA"
        Icon="Assets/brand.png">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#F2F6FA" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TitleBrush" Color="#12324E" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7E8F" />
        <SolidColorBrush x:Key="LineBrush" Color="#D3DEE8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E6FA8" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#175B89" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B4493D" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#983A31" />
        <SolidColorBrush x:Key="AccentBrush" Color="#E09A34" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#EDF3F8" />
            <Setter Property="Foreground" Value="#194666" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DDEAF4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#FCFEFF" />
            <Setter Property="AlternatingRowBackground" Value="#F3F8FC" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EAF1F7" />
            <Setter Property="Foreground" Value="#163752" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="14" Margin="0,0,0,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1D5E90" />
                    <GradientStop Offset="1" Color="#1A8DA4" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="56" Height="56" CornerRadius="10" Background="#EEF6FB" VerticalAlignment="Center">
                    <Image Source="Assets/brand.png" Stretch="Uniform" Margin="6" />
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Localizer[AppTitle]}" FontSize="26" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="{Binding Localizer[AppSubtitle]}" FontSize="13" Foreground="#E4F4FF" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <TextBlock Text="{Binding Localizer[Language]}" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Width="110"
                              SelectedValuePath="Language"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding Localizer.LanguageOptions}"
                              SelectedValue="{Binding Localizer.CurrentLanguage, Mode=TwoWay}"
                              SelectionChanged="LanguageSelection_Changed" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButtonStyle}" Width="176" Height="46" FontSize="15" Click="StartSession_Click" Content="{Binding Localizer[StartSession]}" />
                    <Button Style="{StaticResource DangerButtonStyle}" Width="176" Height="46" FontSize="15" Click="StopSession_Click" Content="{Binding Localizer[StopSession]}" />
                    <Button Style="{StaticResource FlatButtonStyle}" Width="176" Click="AddInterceptRuleAtoB_Click" Content="{Binding Localizer[AddInterceptRuleAtoB]}" />
                    <Button Style="{StaticResource FlatButtonStyle}" Width="176" Margin="0" Click="AddInterceptRuleBtoA_Click" Content="{Binding Localizer[AddInterceptRuleBtoA]}" />
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#EDF4FA" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock Text="{Binding SessionManager.Status, Mode=OneWay}" Foreground="#1C4D6E" FontWeight="SemiBold" />
                    </Border>
                    <Border Background="#FFF5E7" CornerRadius="8" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Localizer[Visible]}" Foreground="#7D4A0A" FontWeight="SemiBold" />
                            <TextBlock Text=": " Foreground="#7D4A0A" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LiveMonitor.VisibleFrames.Count, Mode=OneWay}" Foreground="#7D4A0A" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Background="#F4F8FC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                    <WrapPanel>
                        <Border Background="#E6F2FD" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Localizer[DirAtoB]}" Foreground="#0F4D77" FontWeight="SemiBold" />
                                <TextBlock Text=" " Foreground="#0F4D77" />
                                <TextBlock Text="{Binding LiveMonitor.AToBBytesPerSec, Mode=OneWay}" Foreground="#0F4D77" FontWeight="SemiBold" />
                                <TextBlock Text=" " Foreground="#0F4D77" />
                                <TextBlock Text="{Binding Localizer[BytesPerSec]}" Foreground="#0F4D77" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF0DD" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Localizer[DirBtoA]}" Foreground="#8A5200" FontWeight="SemiBold" />
                                <TextBlock Text=" " Foreground="#8A5200" />
                                <TextBlock Text="{Binding LiveMonitor.BToABytesPerSec, Mode=OneWay}" Foreground="#8A5200" FontWeight="SemiBold" />
                                <TextBlock Text=" " Foreground="#8A5200" />
                                <TextBlock Text="{Binding Localizer[BytesPerSec]}" Foreground="#8A5200" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Background="#ECF7EF" CornerRadius="8" Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Localizer[FramesPerSec]}" Foreground="#2D6940" FontWeight="SemiBold" />
                                <TextBlock Text=" " Foreground="#2D6940" />
                                <TextBlock Text="{Binding LiveMonitor.FramesPerSec, Mode=OneWay}" Foreground="#2D6940" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[SessionOverview]}" />
                            <TextBlock Text="{Binding Localizer[Direction]}" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding Localizer[DirectionEndpoints]}" Foreground="{StaticResource TitleBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Localizer[CaptureFolder]}" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding ReplayController.CaptureFolder, Mode=OneWay}" TextWrapping="Wrap" Foreground="{StaticResource TitleBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[ReplayControl]}" />
                            <TextBlock Text="{Binding Localizer[CaptureFolder]}" Foreground="{StaticResource MutedBrush}" />
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Padding="8,6" Text="{Binding ReplayController.CaptureFolder}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Width="96"
                                        Margin="0"
                                        Click="BrowseReplayFolder_Click"
                                        Content="{Binding Localizer[Browse]}" />
                            </Grid>
                            <TextBlock Text="{Binding Localizer[SpeedFactor]}" Foreground="{StaticResource MutedBrush}" />
                            <TextBox Margin="0,4,0,12" Width="110" Padding="8,6" Text="{Binding ReplayController.SpeedFactor}" />
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource FlatButtonStyle}" Width="94" Click="LoadReplay_Click" Content="{Binding Localizer[Load]}" />
                                <Button Style="{StaticResource FlatButtonStyle}" Width="94" Click="ReplayAll_Click" Content="{Binding Localizer[Replay]}" />
                                <Button Style="{StaticResource FlatButtonStyle}" Width="94" Margin="0" Click="ReplayStep_Click" Content="{Binding Localizer[Step]}" />
                            </StackPanel>
                            <Button Style="{StaticResource FlatButtonStyle}"
                                    Width="220"
                                    Margin="0,10,0,0"
                                    Click="SaveCurrentCaptureForReplay_Click"
                                    Content="{Binding Localizer[SaveCurrentCaptureForReplay]}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[QuickNotes]}" />
                            <TextBlock Text="{Binding Localizer[QuickNote1], StringFormat=• {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Localizer[QuickNote2], StringFormat=• {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Localizer[QuickNote3], StringFormat=• {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Localizer[QuickNote4], StringFormat=• {0}}" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10">
                <TabControl>
                    <TabItem Header="{Binding Localizer[TabLiveMonitor]}">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Background="#EFF5FA" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                                <DockPanel LastChildFill="False">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding Localizer[Filter]}" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                        <TextBox Width="280" Padding="8,5"
                                                 Text="{Binding LiveMonitor.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                        <Separator Margin="10,0" Width="1" />
                                        <CheckBox Content="{Binding Localizer[FilterAtoB]}" IsChecked="{Binding LiveMonitor.ShowAtoB}" Margin="6,0" VerticalAlignment="Center" />
                                        <CheckBox Content="{Binding Localizer[FilterBtoA]}" IsChecked="{Binding LiveMonitor.ShowBtoA}" Margin="6,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <TextBlock Text="{Binding Localizer[PayloadFormat]}" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                        <RadioButton x:Name="ShowHexColumnRadioButton" GroupName="LiveMonitorPayloadFormat" Content="{Binding Localizer[Hex]}" IsChecked="True" Margin="0,0,8,0" VerticalAlignment="Center"
                                                     Checked="LiveMonitorColumnToggle_Changed" />
                                        <RadioButton x:Name="ShowAsciiColumnRadioButton" GroupName="LiveMonitorPayloadFormat" Content="{Binding Localizer[Ascii]}" Margin="0,0,8,0" VerticalAlignment="Center"
                                                     Checked="LiveMonitorColumnToggle_Changed" />
                                        <Button Style="{StaticResource FlatButtonStyle}" Width="96" Margin="0" Click="LiveMonitorClear_Click" Content="{Binding Localizer[Clear]}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#F9FCFF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="InboundMonitorTitleText" FontSize="14" FontWeight="SemiBold" Foreground="#0F4D77" Margin="0,0,0,8" />
                                        <DataGrid x:Name="InboundMonitorGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding LiveMonitor.InboundVisibleFrames}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  SelectionMode="Extended"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem x:Name="InboundMonitorCopyHexMenuItem" Header="Copy HEX" Click="LiveMonitorCopyHex_Click" />
                                                    <MenuItem x:Name="InboundMonitorCopyAsciiMenuItem" Header="Copy ASCII" Click="LiveMonitorCopyAscii_Click" />
                                                    <Separator />
                                                    <MenuItem x:Name="InboundMonitorExportMenuItem" Header="Export Selected Frames..." Click="LiveMonitorExportSelected_Click" />
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="#FBFEFF" />
                                                    <Setter Property="Foreground" Value="#15334D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="AtoB">
                                                            <Setter Property="Background" Value="#ECF6FF" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Direction}" Value="BtoA">
                                                            <Setter Property="Background" Value="#FFF7EC" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn x:Name="InboundTimestampColumn" Header="Timestamp"
                                                                    Width="200"
                                                                    Binding="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss.fff}, Mode=OneWay}" />
                                                <DataGridTemplateColumn x:Name="InboundDirectionColumn" Header="Direction" Width="118">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#D9ECFD" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="BtoA">
                                                                                <Setter Property="Background" Value="#FDE7C7" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="A -> B" />
                                                                            <Setter Property="Foreground" Value="#0E4E7A" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Direction}" Value="BtoA">
                                                                                    <Setter Property="Text" Value="B -> A" />
                                                                                    <Setter Property="Foreground" Value="#8A5200" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn x:Name="InboundLengthColumn" Header="Length" Width="90" Binding="{Binding Length, Mode=OneWay}" />
                                                <DataGridTextColumn x:Name="InboundHexPayloadColumn" Header="HEX Payload" Width="*" Binding="{Binding Hex, Mode=OneWay}" />
                                                <DataGridTextColumn x:Name="InboundAsciiPayloadColumn" Header="ASCII" Width="260" Binding="{Binding Ascii, Mode=OneWay}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Background="#FBFAFF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="ForwardedMonitorTitleText" FontSize="14" FontWeight="SemiBold" Foreground="#344A92" />
                                        <TextBlock x:Name="ForwardedMonitorHintText" Grid.Row="1" Margin="0,4,0,8" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <DataGrid x:Name="ForwardedMonitorGrid"
                                                  Grid.Row="2"
                                                  ItemsSource="{Binding LiveMonitor.ForwardedVisibleFrames}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  SelectionMode="Extended"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem x:Name="ForwardedMonitorCopyHexMenuItem" Header="Copy HEX" Click="LiveMonitorCopyHex_Click" />
                                                    <MenuItem x:Name="ForwardedMonitorCopyAsciiMenuItem" Header="Copy ASCII" Click="LiveMonitorCopyAscii_Click" />
                                                    <Separator />
                                                    <MenuItem x:Name="ForwardedMonitorExportMenuItem" Header="Export Selected Frames..." Click="LiveMonitorExportSelected_Click" />
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="#EEF1FF" />
                                                    <Setter Property="Foreground" Value="#15334D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                            <Setter Property="Background" Value="#FFE2A8" />
                                                            <Setter Property="Foreground" Value="#7A4300" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Direction}" Value="BtoA" />
                                                                <Condition Binding="{Binding IsModified}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#F8F0FF" />
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Direction}" Value="BtoA" />
                                                                <Condition Binding="{Binding IsModified}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#FFD292" />
                                                            <Setter Property="Foreground" Value="#7A4300" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn x:Name="ForwardedTimestampColumn" Header="Timestamp"
                                                                    Width="200"
                                                                    Binding="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss.fff}, Mode=OneWay}" />
                                                <DataGridTemplateColumn x:Name="ForwardedStatusColumn" Header="Status" Width="108">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#E8E9FB" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                                <Setter Property="Background" Value="#FFCE73" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Text="{Binding DataContext.Localizer[FrameOriginal], RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               Foreground="#344A92">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Text="{Binding DataContext.Localizer[FrameModified], RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               Foreground="#7A4300">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn x:Name="ForwardedDirectionColumn" Header="Direction" Width="118">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#D9ECFD" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="BtoA">
                                                                                <Setter Property="Background" Value="#FDE7C7" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="A -> B" />
                                                                            <Setter Property="Foreground" Value="#0E4E7A" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Direction}" Value="BtoA">
                                                                                    <Setter Property="Text" Value="B -> A" />
                                                                                    <Setter Property="Foreground" Value="#8A5200" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn x:Name="ForwardedLengthColumn" Header="Length" Width="90" Binding="{Binding Length, Mode=OneWay}" />
                                                <DataGridTextColumn x:Name="ForwardedHexPayloadColumn" Header="HEX Payload" Width="*" Binding="{Binding Hex, Mode=OneWay}" />
                                                <DataGridTextColumn x:Name="ForwardedAsciiPayloadColumn" Header="ASCII" Width="260" Binding="{Binding Ascii, Mode=OneWay}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{Binding Localizer[TabInterceptQueue]}">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Background="#F4F8FC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding InterceptQueue.ModeTitle}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" />
                                        <TextBlock Text="{Binding InterceptQueue.ModeDescription}" Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#E6F2FD" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Localizer[PendingRequests]}" Foreground="#0F4D77" FontWeight="SemiBold" />
                                                <TextBlock Text=": " Foreground="#0F4D77" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding InterceptQueue.PendingCount}" Foreground="#0F4D77" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Width="150"
                                                Margin="0"
                                                Click="ToggleInterceptMode_Click"
                                                Content="{Binding InterceptQueue.ToggleButtonText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid x:Name="InterceptGrid"
                                      Grid.Row="1"
                                      Margin="0,8,0,0"
                                      ItemsSource="{Binding InterceptQueue.Pending}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectionChanged="InterceptGrid_SelectionChanged"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn x:Name="InterceptDirectionColumn" Header="Direction" Width="120" IsReadOnly="True" Binding="{Binding Request.Frame.Direction, Mode=OneWay}" />
                                    <DataGridTextColumn x:Name="InterceptLengthColumn" Header="Length" Width="100" IsReadOnly="True" Binding="{Binding Request.Frame.Payload.Length, Mode=OneWay}" />
                                    <DataGridTemplateColumn x:Name="InterceptEditableHexColumn" Header="Editable HEX" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding EditedHex, Mode=OneWay}" VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Padding="6,4"
                                                         VerticalContentAlignment="Center"
                                                         Text="{Binding EditedHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="12,10"
                                    Background="#F8FBFE"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.ColumnSpan="14"
                                               Text="{Binding Localizer[ChecksumToolTitle]}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TitleBrush}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Localizer[ChecksumAlgorithm]}" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              ItemsSource="{Binding ChecksumTool.AlgorithmOptions}"
                                              SelectedItem="{Binding ChecksumTool.SelectedAlgorithm, Mode=TwoWay}"
                                              DisplayMemberPath="Label"
                                              IsEnabled="{Binding ChecksumTool.IsReady}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Text="{Binding Localizer[ChecksumValue]}" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="4"
                                             Padding="8,6"
                                             Text="{Binding ChecksumTool.ComputedHex, Mode=OneWay}"
                                             IsReadOnly="True" />

                                    <TextBlock Grid.Row="1" Grid.Column="6" VerticalAlignment="Center" Text="{Binding Localizer[ChecksumByteOrder]}" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="7"
                                              ItemsSource="{Binding ChecksumTool.ByteOrderOptions}"
                                              SelectedItem="{Binding ChecksumTool.SelectedByteOrder, Mode=TwoWay}"
                                              DisplayMemberPath="Label"
                                              IsEnabled="{Binding ChecksumTool.IsReady}" />

                                    <TextBlock Grid.Row="1" Grid.Column="9" VerticalAlignment="Center" Text="{Binding Localizer[ChecksumStartOffset]}" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="10"
                                             Padding="8,6"
                                             Text="{Binding ChecksumTool.StartOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding ChecksumTool.IsReady}" />

                                    <TextBlock Grid.Row="1" Grid.Column="12" VerticalAlignment="Center" Text="{Binding Localizer[ChecksumEndOffset]}" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="13"
                                             Padding="8,6"
                                             Text="{Binding ChecksumTool.EndOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding ChecksumTool.IsReady}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,8,0" Text="{Binding Localizer[ChecksumWriteOffset]}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Padding="8,6"
                                             Margin="0,10,0,0"
                                             Text="{Binding ChecksumTool.WriteOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding ChecksumTool.IsReady}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="3"
                                               Grid.ColumnSpan="11"
                                               Margin="0,10,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding Localizer[ChecksumAutoOffsetHint]}" />

                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="14" Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Style="{StaticResource FlatButtonStyle}"
                                                Width="150"
                                                Click="OverwriteTailChecksum_Click"
                                                Content="{Binding Localizer[OverwriteTailChecksum]}"
                                                IsEnabled="{Binding ChecksumTool.IsReady}" />
                                        <Button Style="{StaticResource FlatButtonStyle}"
                                                Width="120"
                                                Margin="0"
                                                Click="AppendChecksum_Click"
                                                Content="{Binding Localizer[AppendChecksum]}"
                                                IsEnabled="{Binding ChecksumTool.IsReady}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DockPanel Grid.Row="3" Margin="0,8,0,0" LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding ChecksumTool.ScopeDescription, Mode=OneWay}" />
                                <TextBlock DockPanel.Dock="Right"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#7A5A18"
                                           Text="{Binding ChecksumTool.StatusText, Mode=OneWay}" />
                            </DockPanel>

                            <WrapPanel Grid.Row="4" Margin="0,10,0,0">
                                <Button Style="{StaticResource FlatButtonStyle}" Width="100" Click="ForwardIntercept_Click" Content="{Binding Localizer[Forward]}" IsEnabled="{Binding InterceptQueue.IsIntercepting}" />
                                <Button Style="{StaticResource FlatButtonStyle}" Width="100" Click="DropIntercept_Click" Content="{Binding Localizer[Drop]}" IsEnabled="{Binding InterceptQueue.IsIntercepting}" />
                                <Button Style="{StaticResource FlatButtonStyle}" Width="100" Margin="0" Click="RepeatIntercept_Click" Content="{Binding Localizer[RepeatX2]}" ToolTip="{Binding Localizer[RepeatX2Hint]}" IsEnabled="{Binding InterceptQueue.IsIntercepting}" />
                            </WrapPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{Binding Localizer[TabRuleEditor]}">
                        <DataGrid x:Name="RuleEditorGrid"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding RuleEditor.Rules}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  PreviewMouseRightButtonDown="RuleEditorGrid_PreviewMouseRightButtonDown"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="RuleAddHexMonitorMenuItem" Header="Add HEX Filter Rule..." Click="AddHexMonitorRule_Click" />
                                    <MenuItem x:Name="RuleAddAsciiMonitorMenuItem" Header="Add ASCII Match Rule..." Click="AddAsciiMonitorRule_Click" />
                                    <Separator />
                                    <MenuItem x:Name="RuleDeleteMenuItem" Header="Delete Rule" Click="DeleteRule_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="RuleNameColumn" Header="Rule Name" Width="280" IsReadOnly="True" Binding="{Binding Name, Mode=OneWay}" />
                                <DataGridTemplateColumn x:Name="RuleEnabledColumn" Header="Enabled" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Checked="RuleEnabledCheckBox_Changed"
                                                      Unchecked="RuleEnabledCheckBox_Changed" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn x:Name="RuleScopeColumn" Header="Scope" Width="118">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E6F2FD" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Scope}" Value="Monitor">
                                                                <Setter Property="Background" Value="#FFF0DD" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DataContext.Localizer[RuleScopeProxy], RelativeSource={RelativeSource AncestorType=Window}}"
                                                               Foreground="#0F4D77">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Scope}" Value="Monitor">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DataContext.Localizer[RuleScopeMonitor], RelativeSource={RelativeSource AncestorType=Window}}"
                                                               Foreground="#8A5200">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Scope}" Value="Monitor">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="RuleMatchersColumn" Header="Matchers" Width="*" IsReadOnly="True" Binding="{Binding Matchers.Count, Mode=OneWay}" />
                                <DataGridTextColumn x:Name="RuleActionsColumn" Header="Actions" Width="*" IsReadOnly="True" Binding="{Binding Actions.Count, Mode=OneWay}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="{Binding Localizer[TabConfigEditor]}">
