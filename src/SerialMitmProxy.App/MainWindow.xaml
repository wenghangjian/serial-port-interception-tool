                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[CfgSectionRuntime]}" />
                                            <TextBlock Grid.Row="1" Text="{Binding Localizer[CfgFieldFixedLength]}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Padding="8,5"
                                                     Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigEditor.DecoderFixedLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="2" Text="{Binding Localizer[CfgFieldCaptureFolder]}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Padding="8,5" Margin="0,6,0,0"
                                                     Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigEditor.CaptureFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="3" Text="{Binding Localizer[CfgFieldMonitorMaxFrames]}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                            <TextBox Grid.Row="3" Grid.Column="1" Padding="8,5" Margin="0,6,0,0"
                                                     Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigEditor.MonitorMaxFrames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="4" Text="{Binding Localizer[CfgFieldMonitorUiThrottleMs]}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                            <TextBox Grid.Row="4" Grid.Column="1" Padding="8,5" Margin="0,6,0,0"
                                                     Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigEditor.MonitorUiThrottleMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="5" Text="{Binding Localizer[CfgFieldPluginsFolder]}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                            <TextBox Grid.Row="5" Grid.Column="1" Padding="8,5" Margin="0,6,0,0"
                                                     Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigEditor.PluginsFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{Binding Localizer[TabConfigHelp]}">
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding Localizer[ConfigHelpTitle]}" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding Localizer[ConfigHelpIntro]}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[ConfigSessionSection]}" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionUseInMemory], StringFormat=session.useInMemory: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionEndpointA], StringFormat=session.endpointA: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionEndpointB], StringFormat=session.endpointB: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionDecoderMode], StringFormat=session.decoders.mode: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionDecoderTimeSlice], StringFormat=session.decoders.timeSliceMs: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionDecoderDelimiter], StringFormat=session.decoders.delimiterHex: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgSessionDecoderFixedLength], StringFormat=session.decoders.fixedLength: {0}}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[ConfigCaptureSection]}" />
                                        <TextBlock Text="{Binding Localizer[CfgCaptureEnabled], StringFormat=capture.enabled: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgCaptureFolder], StringFormat=capture.folder: {0}}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[ConfigMonitorSection]}" />
                                        <TextBlock Text="{Binding Localizer[CfgMonitorMaxFrames], StringFormat=monitor.maxFrames: {0}}" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Localizer[CfgMonitorUiThrottle], StringFormat=monitor.uiThrottleMs: {0}}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[ConfigPluginSection]}" />
                                        <TextBlock Text="{Binding Localizer[CfgPluginsFolder], StringFormat=plugins.folder: {0}}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Margin="0,10,0,0" Background="#E8F0F7" BorderBrush="#D3DEE8" BorderThickness="1">
            <StatusBarItem>
                <TextBlock Text="{Binding Localizer[Status]}" FontWeight="SemiBold" Foreground="#204864" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text=": " FontWeight="SemiBold" Foreground="#204864" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding SessionManager.Status, Mode=OneWay}" Foreground="#204864" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Localizer[StatusObservedFrames]}" Foreground="#204864" />
                    <TextBlock Text=": " Foreground="#204864" />
                    <TextBlock Text="{Binding LiveMonitor.Frames.Count, Mode=OneWay}" Foreground="#204864" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
