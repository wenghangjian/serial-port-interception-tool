                                            <TextBlock Grid.Row="2" Text="{Binding Localizer[CfgFieldBaudRate]}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Padding="8,5" Margin="0,6,0,0"
