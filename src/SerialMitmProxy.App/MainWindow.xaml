                                                <TextBlock Style="{StaticResource CardTitleStyle}" Text="{Binding Localizer[CfgSectionEndpointA]}" Margin="0,0,0,2" />
                                                <TextBlock Text="{Binding Localizer[CfgSectionEndpointAHintShort]}" Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Localizer[CfgFieldPortName]}" VerticalAlignment="Center" />
